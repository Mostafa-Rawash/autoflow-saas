# Server
PORT=3002
HOST=0.0.0.0

# External Services
GEMINI_ROBOT_URL=http://localhost:3001
DATABASE_ROBOT_URL=http://localhost:3000
GEMINI_ROBOT_API_KEY=whatsapp-robot-secret-key
DATABASE_ROBOT_API_KEY=database-robot-secret-key

# WhatsApp Configuration
# Leave empty to allow all numbers, or specify comma-separated numbers
AUTHORIZED_NUMBERS=
MAX_CONCURRENT_CONVERSATIONS=3
SESSION_SAVE_PATH=./sessions
CONVERSATION_TIMEOUT_MS=1800000

# HTTP Client
HTTP_TIMEOUT_MS=30000
HTTP_MAX_RETRIES=5
HTTP_RETRY_DELAY_MS=1000
HTTP_CIRCUIT_BREAKER_THRESHOLD=5
HTTP_CIRCUIT_BREAKER_COOLDOWN_MS=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# API Security
WHATSAPP_ROBOT_API_KEY=whatsapp-robot-secret-key

# Logging
LOG_LEVEL=info
LOG_MAX_FILES=14
LOG_MAX_SIZE=20M

# Message Queue
MESSAGE_QUEUE_MAX_SIZE=1000
MESSAGE_RETRY_MAX_ATTEMPTS=3

# Puppeteer
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=120000
PUPPETEER_USER_DATA_DIR=./whatsapp-user-data

# Environment
NODE_ENV=development
