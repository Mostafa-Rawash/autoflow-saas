# Gemini Robot Service Configuration
# Copy this file to .env and fill in your actual values

# Required: Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini Model to use (defaults to gemini-3-flash-preview)
# Available options: gemini-2.5-flash, gemini-2.0-flash, gemini-2.0-pro, etc.
GEMINI_MODEL=gemini-3-flash-preview

# Optional: Fallback model when primary fails (defaults to gemini-2.5-flash-preview)
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-preview

# Optional: Server port (defaults to 3001)
PORT=3001

# Optional: Database Robot Service URL (defaults to http://localhost:3000)
DATABASE_ROBOT_URL=http://localhost:3000

# Optional: Database Robot API Key (defaults to shared-secret-key)
DATABASE_ROBOT_API_KEY=shared-secret-key
