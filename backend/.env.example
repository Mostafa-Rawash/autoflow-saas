# AutoFlow Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# JWT Secret - MUST be set to a strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ===========================================
# DATABASE
# ===========================================

# MongoDB Connection URI
# Leave empty to use in-memory MongoDB (data lost on restart)
# Example: mongodb://localhost:27017/autoflow
# Or MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/autoflow
MONGODB_URI=

# ===========================================
# REDIS (Optional - improves performance)
# ===========================================

# Redis URL for caching and rate limiting
# Leave empty to use in-memory cache
# Example: redis://localhost:6379
# With auth: redis://:password@redis.example.com:6379
REDIS_URL=

# ===========================================
# SERVER
# ===========================================

# Server Port (default: 5000)
PORT=5000

# Frontend URL for CORS
# Example: http://localhost:3000 or https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# ===========================================
# WHATSAPP
# ===========================================

# Maximum concurrent WhatsApp connections
MAX_WHATSAPP_CLIENTS=10

# ===========================================
# ADMIN (Optional)
# ===========================================

# Super Admin - created on database seed
# SUPER_ADMIN_EMAIL=admin@yourcompany.com
# SUPER_ADMIN_PASSWORD=Admin123!

# ===========================================
# RATE LIMITING
# ===========================================

# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP
RATE_LIMIT_MAX=100

# ===========================================
# OPTIONAL INTEGRATIONS
# ===========================================

# Twilio (SMS)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email (SMTP)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ===========================================
# PAYMENT (Coming Soon)
# ===========================================

# Fawry
# FAWRY_MERCHANT_CODE=
# FAWRY_SECURITY_KEY=

# Vodafone Cash
# VODAFONE_CASH_API_KEY=